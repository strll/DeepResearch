# =============================================================================
# Deep Research 环境变量配置
# =============================================================================
# 使用方式：复制本文件为 .env，按需修改对应值
#   cp .env.example .env
#
# 所有字段均有默认值，未设置的项将使用代码中的默认值。
# 带 # 号注释掉的为可选配置，取消注释后填入实际值即可启用。
# =============================================================================

# ------------------------------
# 应用基础配置
# ------------------------------
APP_NAME="AI 研究报告工作台"
APP_VERSION="0.1.0"
ENVIRONMENT=local
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# ------------------------------
# 数据存储
# ------------------------------
# MongoDB 连接串（本地开发默认值可直接使用）
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=deep_research
REDIS_URL=redis://localhost:6380/0

# ------------------------------
# LLM 大模型配置
# ------------------------------
# 模型提供商：openai / deepseek
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4.1-mini
LLM_TEMPERATURE=0.2

# OpenAI 接口（使用 OpenAI 兼容 API 时填写）
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=sk-xxxxxxxx

# DeepSeek 接口（使用 DeepSeek 时填写）
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# DEEPSEEK_API_KEY=sk-xxxxxxxx

# ------------------------------
# RAGFlow 检索增强（可选）
# ------------------------------
# RAGFLOW_BASE_URL=http://localhost:9380
# RAGFLOW_API_KEY=your-ragflow-api-key
# RAGFLOW_DEFAULT_DATASET_IDS=dataset-id-1,dataset-id-2

# ------------------------------
# Tavily 外部搜索（可选）
# ------------------------------
# TAVILY_API_KEY=tvly-xxxxxxxx

# ------------------------------
# 对象存储（MinIO / S3 兼容）
# ------------------------------
OBJECT_STORAGE_BUCKET=deep-research

# ------------------------------
# LangSmith 追踪（可选）
# ------------------------------
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=your-langsmith-api-key
# LANGSMITH_PROJECT=deep_research
